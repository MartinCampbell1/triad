{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://triad.dev/schemas/stream-event.schema.json",
  "title": "Triad Stream Event",
  "schema_version": 1,
  "aliases": {
    "message_delta": "text_delta",
    "message_completed": "message_finalized",
    "tool_started": "tool_use",
    "tool_finished": "tool_result",
    "completed": "run_completed",
    "error": "run_failed",
    "status": "system"
  },
  "groups": {
    "message_event_types": ["message_finalized"],
    "tool_event_types": ["tool_use", "tool_result"],
    "system_notice_event_types": ["system", "stderr", "run_failed", "review_finding", "diff_snapshot"],
    "terminal_completion_event_types": ["run_completed", "run_failed"]
  },
  "field_types": {
    "schema_version": "integer",
    "session_id": "string",
    "run_id": "string",
    "provider": "string",
    "role": "string",
    "source": "string",
    "timestamp": "string",
    "authoritative": "boolean",
    "message_id": "string",
    "tool": "string",
    "input": "any",
    "output": "any",
    "status": "string",
    "success": "boolean",
    "delta": "string",
    "content": "string",
    "error": "string",
    "severity": "string",
    "file": "string",
    "line": "integer",
    "line_range": "string",
    "title": "string",
    "explanation": "string",
    "path": "string",
    "old_text": "string",
    "new_text": "string",
    "terminal_id": "string",
    "data": "string"
  },
  "event_types": [
    { "type": "text_delta", "required": ["delta"] },
    { "type": "message_finalized", "required": ["content"] },
    { "type": "tool_use", "required": ["tool", "status"] },
    { "type": "tool_result", "required": ["tool", "status"] },
    { "type": "review_finding", "required": ["severity", "file", "title", "explanation"] },
    { "type": "diff_snapshot", "required": ["path", "old_text", "new_text"] },
    { "type": "stderr", "required": ["data"] },
    { "type": "run_completed", "required": [] },
    { "type": "run_failed", "required": ["error"] },
    { "type": "terminal_output", "required": ["terminal_id", "data"] },
    { "type": "system", "required": ["content"] }
  ],
  "type": "object",
  "required": ["schema_version", "session_id", "type"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "text_delta",
        "message_finalized",
        "tool_use",
        "tool_result",
        "review_finding",
        "diff_snapshot",
        "stderr",
        "run_completed",
        "run_failed",
        "terminal_output",
        "system"
      ]
    },
    "provider": {
      "type": "string",
      "enum": ["claude", "codex", "gemini"]
    },
    "role": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "authoritative": {
      "type": "boolean"
    },
    "message_id": {
      "type": "string"
    },
    "tool": {
      "type": "string"
    },
    "input": {},
    "output": {},
    "status": {
      "type": "string",
      "enum": ["running", "completed", "failed"]
    },
    "success": {
      "type": "boolean"
    },
    "delta": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "error": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": ["P0", "P1", "P2", "P3"]
    },
    "file": {
      "type": "string"
    },
    "line": {
      "type": "integer",
      "minimum": 1
    },
    "line_range": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "explanation": {
      "type": "string"
    },
    "path": {
      "type": "string"
    },
    "old_text": {
      "type": "string"
    },
    "new_text": {
      "type": "string"
    },
    "terminal_id": {
      "type": "string"
    },
    "data": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "text_delta"
          }
        }
      },
      "then": {
        "required": ["delta"]
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "message_finalized"
          }
        }
      },
      "then": {
        "required": ["content"]
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "tool_use"
          }
        }
      },
      "then": {
        "required": ["tool", "status"]
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "tool_result"
          }
        }
      },
      "then": {
        "required": ["tool", "status"]
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "review_finding"
          }
        }
      },
      "then": {
        "required": ["severity", "file", "title", "explanation"]
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "diff_snapshot"
          }
        }
      },
      "then": {
        "required": ["path", "old_text", "new_text"]
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "stderr"
          }
        }
      },
      "then": {
        "required": ["data"]
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "run_failed"
          }
        }
      },
      "then": {
        "required": ["error"]
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "terminal_output"
          }
        }
      },
      "then": {
        "required": ["terminal_id", "data"]
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "system"
          }
        }
      },
      "then": {
        "required": ["content"]
      }
    }
  ]
}
