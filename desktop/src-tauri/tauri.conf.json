{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Triad",
  "version": "0.1.0",
  "identifier": "com.triad.desktop",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "beforeBuildCommand": "corepack pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Triad",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 720,
        "decorations": true,
        "transparent": false,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/triad-bridge"]
  }
}
